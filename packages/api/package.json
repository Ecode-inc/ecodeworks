{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute ecode-db --remote --file=./migrations/0001_init.sql",
    "db:migrate:local": "wrangler d1 execute ecode-db --local --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.0.6",
    "hono": "^4.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "wrangler": "^3.57.0"
  }
}
